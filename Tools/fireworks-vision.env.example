# Copy to Tools/fireworks-vision.env (gitignored) or rely on User-scope FIREWORKS_API_KEY
# (same variable as Dino/scripts/proof/test-fireworks-kimi.ps1).
#
# Requires a Fireworks *inference* API key (dashboard API keys), NOT a Fire Pass key (fpk_*).
# Fire Pass keys return HTTP 403: "Fire Pass API keys are not authorized for this route."
#
# Vision model must support image_url; kimi-k2-instruct is deprecated (404). Use kimi-k2p5:
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p5
# Optional override for all PlayCUA/live-verify runs:
# PLAYCUA_VISION_BACKEND=fireworks
