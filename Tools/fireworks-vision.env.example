# Copy to Tools/fireworks-vision.env (gitignored) or rely on User-scope FIREWORKS_API_KEY
# (same key as Dino/scripts/proof/test-fireworks-kimi.ps1).
# Vision model must support image_url; kimi-k2-instruct is text-only and returns 404.
FIREWORKS_API_KEY=
FIREWORKS_BASE_URL=https://api.fireworks.ai/inference/v1
FIREWORKS_VISION_MODEL=accounts/fireworks/models/kimi-k2p5
# Optional override for all PlayCUA/live-verify runs:
# PLAYCUA_VISION_BACKEND=fireworks
