# Copy to a local file (e.g. Tools/omniroute-vision.env) and fill OMNROUTE_API_KEY.
# Create the combo in OmniRoute Dashboard → Combos with multiple VLM models for consensus/fallback.
# Local default; on another machine use Tailscale IP, e.g. http://100.112.14.98:20128/v1
# (Funnel URLs like https://<machine>.tail*.ts.net may be offline while the peer is up.)
OMNROUTE_BASE_URL=http://127.0.0.1:20128/v1
OMNROUTE_API_KEY=
# Prefer a vision-capable model id when combos do not forward images; otherwise set a combo name.
OMNROUTE_VISION_MODEL=gemini/gemini-2.5-flash
# OMNROUTE_VISION_COMBO=wsm3d-vision-frontier
